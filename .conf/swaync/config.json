{
  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-margin-top": 30,
  "control-center-margin-bottom": 30,
  "control-center-margin-right": 30,
  "control-center-margin-left": 30,
  "control-center-width": 380,
  "control-center-height": 720,
  "fit-to-screen": false,
  "layer": "overlay",
  "cssPriority": "user",
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 8,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-window-width": 350,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "inhibitors": { "text": "Не беспокоить включено", "button-text": "Выключить", "height": 60 },
    "title": { "text": "Уведомления", "clear-all-button": true, "button-text": "Очистить всё" },
    "dnd": { "text": "Не беспокоить" },
    "notifications": { "limit": 15, "expander-limits": true }
  }
}
