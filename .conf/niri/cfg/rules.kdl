    window-rule {
        geometry-corner-radius 12 // Set every window radius to 20
        clip-to-geometry true
    }

    layer-rule {
        match namespace="^noctalia-wallpaper*"
        place-within-backdrop true
    }


    window-rule {
        match app-id="Happ"
        // open-maximized true
        open-on-workspace "last"
    }


    window-rule {
        match app-id="Thunar"
        default-column-width { fixed 900; };
    }


  
